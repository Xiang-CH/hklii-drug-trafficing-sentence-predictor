{
  "routes": [
    {
      "route": "/index.html",
      "redirect": "/"
    },
    {
      "route": "/",
      "rewrite": "/api/server"
    },
    {
      "route": "/_serverFn/*",
      "rewrite": "/api/server"
    },
    {
      "route": "/_serverFn/*",
      "methods": [
        "post",
        "get",
        "put",
        "delete",
        "options"
      ],
      "rewrite": "/api/server"
    }
  ],
  "platform": {
    "apiRuntime": "node:20"
  },
  "navigationFallback": {
    "rewrite": "/api/server"
  }
}